# ============================================
# Queue Cure '26 — Server Environment Variables
# ============================================

# Port the Express + Socket.IO server listens on
PORT=4000

# Comma-separated list of allowed frontend origins (CORS)
# Add your deployed client URL here too, e.g. https://queue-cure.vercel.app
CLIENT_ORIGIN=http://localhost:5173,http://localhost:3000

# SQLite database file path (created automatically on first run)
DB_PATH=./data/queue.db

# Default average consultation time in minutes, used until receptionist sets one
DEFAULT_AVG_CONSULT_MINUTES=8

# Node environment
NODE_ENV=development

# Admin PIN the receptionist screen asks for before allowing "Call Next" / Add Patient
# (simple deterrent against accidental access on a shared waiting-room tablet)
RECEPTIONIST_PIN=1234
